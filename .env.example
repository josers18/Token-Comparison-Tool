# Copy to .env.local and fill in real values. .env.local is gitignored.

# Salesforce External Client App (ECA) credentials for OAuth 2.1 + PKCE.
# Configure your ECA with:
#   - OAuth 2.1 Authorization Code + PKCE enabled (default for ECAs)
#   - `mcp_api` scope ("Access Salesforce hosted MCP servers")
#   - `cdp_api` scope ("Access all Data Cloud API resources")
#   - `refresh_token` scope
#   - http://localhost:8000/callback in its Callback URL list
# The tool will automatically open a browser to authorize via Salesforce login.
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com
SF_REDIRECT_URI=http://localhost:8000/callback
